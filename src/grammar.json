{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "haikuscript",
  "rules": {
    "program": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "stanza"
          },
          {
            "type": "SYMBOL",
            "name": "newline"
          }
        ]
      }
    },
    "stanza": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "line"
        },
        {
          "type": "SYMBOL",
          "name": "newline"
        },
        {
          "type": "SYMBOL",
          "name": "line"
        },
        {
          "type": "SYMBOL",
          "name": "newline"
        },
        {
          "type": "SYMBOL",
          "name": "line"
        },
        {
          "type": "SYMBOL",
          "name": "newline"
        }
      ]
    },
    "line": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "word"
      }
    },
    "word": {
      "type": "PATTERN",
      "value": "[a-zA-Z]+"
    },
    "newline": {
      "type": "PATTERN",
      "value": "\\n"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\r]+"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}